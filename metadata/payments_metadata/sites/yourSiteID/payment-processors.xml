    <payment-processor processor-id="PAYMENTS_CREDIT">
        <description>Processor for Credit card handling.</description>
        <preferences>
            <all-instances/>
            <development/>
            <staging/>
            <production/>
        </preferences>
    </payment-processor>
    <payment-processor processor-id="PAYMENTS_CLICK_TO_PAY"> 
