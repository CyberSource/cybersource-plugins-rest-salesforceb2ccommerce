<?xml version="1.0" encoding="UTF-8"?>
<metadata xmlns="http://www.demandware.com/xml/impex/metadata/2006-10-31">
    <type-extension type-id="SitePreferences">
        <custom-attribute-definitions>
            <attribute-definition attribute-id="Cybersource_PayerAuthEnabled">
                <display-name xml:lang="x-default">Payer Authentication Mode</display-name>
                <description xml:lang="x-default">Select Payer Authentication mode.</description>
                <type>enum-of-string</type>
                <mandatory-flag>true</mandatory-flag>
                <externally-managed-flag>false</externally-managed-flag>
                <value-definitions>
                    <value-definition>
                        <display xml:lang="x-default">Yes</display>
                        <value>YES</value>
                    </value-definition>
                    <value-definition default="true">
                        <display xml:lang="x-default">No</display>
                        <value>NO</value>
                    </value-definition>
                    <value-definition>
                        <display xml:lang="x-default">Data Only + Yes</display>
                        <value>DATA_ONLY_YES</value>
                    </value-definition>
                    <value-definition>
                        <display xml:lang="x-default">Data Only + No</display>
                        <value>DATA_ONLY_NO</value>
                    </value-definition>
                </value-definitions>
            </attribute-definition>
            <attribute-definition attribute-id="Cybersource_IsSCAEnabled">
                <display-name xml:lang="x-default">Enable SCA</display-name>
                <description xml:lang="x-default">Enable or Disable Strong Customer Authentication</description>
                <type>boolean</type>
                <externally-managed-flag>false</externally-managed-flag>
                <default-value>false</default-value>
            </attribute-definition>
        </custom-attribute-definitions>
        <group-definitions>
            <attribute-group group-id="Cybersource_PayerAuthentication">
                <display-name xml:lang="x-default">Payer Authentication Configuration</display-name>
                <attribute attribute-id="Cybersource_PayerAuthEnabled"/>
                <attribute attribute-id="Cybersource_IsSCAEnabled"/>
            </attribute-group>
        </group-definitions>
    </type-extension>
</metadata>
