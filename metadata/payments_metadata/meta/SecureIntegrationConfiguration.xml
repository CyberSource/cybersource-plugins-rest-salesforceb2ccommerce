<?xml version="1.0" encoding="UTF-8"?>
<metadata xmlns="http://www.demandware.com/xml/impex/metadata/2006-10-31">
    <type-extension type-id="SitePreferences">
        <custom-attribute-definitions>
            <attribute-definition attribute-id="VisaAcceptance_Secure_Integration_Method">
                <display-name xml:lang="x-default">Secure Integration Method</display-name>
                <type>enum-of-string</type>
                <mandatory-flag>false</mandatory-flag>
                <externally-managed-flag>false</externally-managed-flag>
                <value-definitions>
                    <value-definition>
                        <display xml:lang="x-default">Unified Checkout</display>
                        <value>Unified_Checkout</value>
                    </value-definition>
                    <value-definition>
                        <display xml:lang="x-default">Microform</display>
                        <value>Microform</value>
                    </value-definition>
                </value-definitions>
            </attribute-definition>
            <attribute-definition attribute-id="VisaAcceptance_UnifiedCheckout_DigitalPaymentMethods">
                <display-name xml:lang="x-default">Digital Payment Methods in UnifiedCheckout</display-name>
                <type>enum-of-string</type>
                <mandatory-flag>false</mandatory-flag>
                <externally-managed-flag>false</externally-managed-flag>
                <select-multiple-flag>true</select-multiple-flag>
                <value-definitions>
                    <value-definition>
                        <display xml:lang="x-default">GOOGLEPAY</display>
                        <value>GOOGLEPAY</value>
                    </value-definition>
                    <value-definition>
                        <display xml:lang="x-default">APPLEPAY</display>
                        <value>APPLEPAY</value>
                    </value-definition>
                    <value-definition>
                        <display xml:lang="x-default">CLICKTOPAY</display>
                        <value>CLICKTOPAY</value>
                    </value-definition>
                </value-definitions>
            </attribute-definition>
            <attribute-definition attribute-id="VisaAcceptance_UnifiedCheckout_PaymentAcceptanceLocation">
                <display-name xml:lang="x-default">Payment Acceptance Location for UnifiedCheckout</display-name>
                <description xml:lang="x-default">Embedded is loaded in the Checkout page while Sidebar is loaded in the side of the screen.</description>
                <type>enum-of-string</type>
                <mandatory-flag>false</mandatory-flag>
                <externally-managed-flag>false</externally-managed-flag>
                <value-definitions>
                <value-definition default="true">
                <display xml:lang="x-default">Embedded</display>
                <value>Embedded</value>
                </value-definition>
                <value-definition>
                <display xml:lang="x-default">Sidebar</display>
                <value>Sidebar</value>
                </value-definition>
                </value-definitions>
            </attribute-definition>
