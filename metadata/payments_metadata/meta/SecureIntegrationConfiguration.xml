                    </value-definition>
                    <value-definition>
                        <display xml:lang="x-default">CARNET</display>
                        <value>CARNET</value>
                    </value-definition>
                    <value-definition>
                        <display xml:lang="x-default">MADA</display>
                        <value>MADA</value>
                    </value-definition>
                </value-definitions>
            </attribute-definition>
            <attribute-definition attribute-id="VisaAcceptance_UnifiedCheckout_EnableECheck">
                <display-name xml:lang="x-default">Enable E-Check Payment for Unified Checkout</display-name>
                <description xml:lang="x-default">Enable or Disable E-Check Payment for Unified Checkout.</description>
                <type>boolean</type>
                <externally-managed-flag>false</externally-managed-flag>
                <default-value>false</default-value>
            </attribute-definition>
            <attribute-definition attribute-id="Cybersource_CardTransactionType">
                <display-name xml:lang="x-default">Transaction Type</display-name>
                <description xml:lang="x-default">Transaction Type for Credit card and Unified Checkout</description>
                <type>enum-of-string</type>
                <mandatory-flag>false</mandatory-flag>
                <externally-managed-flag>false</externally-managed-flag>
                <value-definitions>
                    <value-definition default="true">
                        <display xml:lang="x-default">Auth</display>
                        <value>auth</value>
                    </value-definition>
                    <value-definition>
                        <display xml:lang="x-default">Sale</display>
                        <value>sale</value>
                    </value-definition>
                </value-definitions>
            </attribute-definition>
            <attribute-definition attribute-id="VisaAcceptance_UnifiedCheckout_Cart_Minicart">
                <display-name xml:lang="x-default">Enable Unified Checkout for Cart and Mini Cart</display-name>
                <description xml:lang="x-default">Enable or Disable Unified Checkout for digital payments on Cart and Mini Cart.</description>
                <type>boolean</type>
                <externally-managed-flag>false</externally-managed-flag>
                <default-value>false</default-value>
            </attribute-definition>
            <attribute-definition attribute-id="VisaAcceptance_UnifiedCheckout_CheckoutLabel">
                <display-name xml:lang="x-default">Checkout Label for Unified Checkout</display-name>
                <description xml:lang="x-default">Label for Unified Checkout Tab on the payment page</description>
                <type>string</type>
                <externally-managed-flag>false</externally-managed-flag>
                <regex>^.{0,60}$</regex>
                <default-value>Secure Payments powered by Visa Acceptance Solutions</default-value>
            </attribute-definition>
